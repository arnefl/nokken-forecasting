# nokken-forecasting environment variables.
#
# Copy to `.env` at the deploy root (e.g. /srv/nokken-forecasting/.env),
# chmod 600, and load into the runtime via EnvironmentFile= on the
# eventual systemd unit. `.env` is gitignored; this file tracks variable
# *names* only. Never commit real values.
#
# Variable names mirror nokken-web (`.env.example`) and nokken-data so
# operators run one set of credentials across the three repos.

# Postgres (nokken-web's `nessie` database). asyncpg-compatible DSN.
# Variable name mirrors `nokken-web/.env.example` and `nokken-data/.env.example`
# so one credential set spans the three repos. The placeholder names the
# `nokken_ro` read-only role used for dev — same role nokken-web's local
# `.env` carries. Phase 2+ will introduce write paths through the
# forecast-sink contract owned by nokken-web (schema lands in a later
# nokken-web PR); the eventual production role must be scoped to permit
# those writes — `nokken_ro` will not suffice.
POSTGRES_DSN=postgresql://nokken_ro:CHANGE_ME@10.0.0.8:5432/nessie

# Logging — DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO
